# Payments Service Configuration
PORT=3002

# PostgreSQL
DATABASE_URL=postgresql://payments_user:payments_pass@localhost:5433/payments_db

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# Orders Service URL (for status updates)
ORDERS_SERVICE_URL=http://localhost:3001

# Stripe API Key
# Get your test key from: https://dashboard.stripe.com/test/apikeys
# Leave as sk_test_placeholder to use simulation mode (no Stripe account needed)
STRIPE_SECRET_KEY=sk_test_placeholder
