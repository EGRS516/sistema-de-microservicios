# ─────────────────────────────────────────────────────────────────────────────
# Stripe — get your TEST key from https://dashboard.stripe.com/test/apikeys
# Leave as-is to use simulation mode (no Stripe account needed)
# ─────────────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_placeholder

# ─────────────────────────────────────────────────────────────────────────────
# These values are used for local development WITHOUT Docker.
# When running with docker-compose, they are automatically overridden.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL_ORDERS=postgresql://orders_user:orders_pass@localhost:5432/orders_db
DATABASE_URL_PAYMENTS=postgresql://payments_user:payments_pass@localhost:5433/payments_db
REDIS_HOST=localhost
REDIS_PORT=6379

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL (Docker Compose)
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_ORDERS_USER=orders_user
POSTGRES_ORDERS_PASSWORD=orders_pass
POSTGRES_ORDERS_DB=orders_db

POSTGRES_PAYMENTS_USER=payments_user
POSTGRES_PAYMENTS_PASSWORD=payments_pass
POSTGRES_PAYMENTS_DB=payments_db
